---
const steps = [
  {
    step: "01",
    title: "Tiếp nhận & Tư vấn",
    desc: "Lắng nghe nhu cầu của khách hàng, phân tích đối thủ cạnh tranh và tư vấn gói thiết kế tối ưu nhất phù hợp ngân sách.",
    color: "from-primary to-info",
    icon: "forum"
  },
  {
    step: "02",
    title: "Trao đổi ý tưởng",
    desc: "Thu thập thông tin thương hiệu, thảo luận ý tưởng layout UI/UX và thống nhất sơ đồ cấu trúc của trang web.",
    color: "from-info to-success",
    icon: "lightbulb"
  },
  {
    step: "03",
    title: "Ký kết hợp đồng",
    desc: "Thống nhất chi phí, điều khoản dịch vụ và tiến hành ký kết hợp đồng chính thức (đặt cọc trước 80%).",
    color: "from-success to-warning",
    icon: "description"
  },
  {
    step: "04",
    title: "Triển khai kỹ thuật",
    desc: "Đội ngũ lập trình viên tiến hành code giao diện, lập trình tính năng và tối ưu hóa tốc độ load trang trong vòng 20 ngày.",
    color: "from-warning to-error",
    icon: "code"
  },
  {
    step: "05",
    title: "Gửi demo & Căn chỉnh",
    desc: "Gửi bản demo chạy thử cho khách hàng trải nghiệm, tiếp nhận phản hồi và tiến hành tinh chỉnh giao diện hoàn hảo.",
    color: "from-error to-secondary",
    icon: "rate_review"
  },
  {
    step: "06",
    title: "Bàn giao & Bảo hành",
    desc: "Bàn giao mã nguồn, hướng dẫn quản trị web chi tiết, tiến hành thanh lý hợp đồng và kích hoạt chế độ bảo hành dài hạn.",
    color: "from-secondary to-primary",
    icon: "verified"
  }
];
---

<section
  id="process"
  class="py-20 md:py-32 px-6 sm:px-8 md:px-12 lg:px-16 bg-gradient-to-br from-base-200 to-base-100 relative overflow-hidden"
>
  <!-- Background Decor Blobs -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-[500px] h-[500px] bg-secondary/5 -top-[100px] -left-[100px]" style="animation-duration: 24s;"></div>
    <div class="floating-blob w-80 h-80 bg-primary/5 bottom-[-100px] right-[-100px]" style="animation-duration: 18s;"></div>
  </div>

  <div class="max-w-[1280px] mx-auto relative z-10">
    <div
      class="text-center mb-20 space-y-4 scroll-animate fade-in-up"
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20">
        <p class="text-xs font-bold text-primary tracking-widest uppercase">
          Quy trình làm việc
        </p>
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-base-content">
        Quy trình Thiết Kế Web Chuyên Nghiệp
      </h2>
      <p
        class="text-base sm:text-lg text-base-content/70 max-w-2xl mx-auto leading-relaxed"
      >
        Quy trình chuẩn mực và minh bạch giúp tối ưu hóa tiến độ và mang lại chất lượng sản phẩm tốt nhất cho doanh nghiệp của bạn.
      </p>
    </div>

    <!-- Process Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {steps.map((item) => (
        <div
          class="card bg-base-100 border border-base-200/50 shadow-xl hover:shadow-2xl hover:border-primary/20 hover:-translate-y-2 transition-all duration-500 group relative overflow-hidden cursor-pointer"
        >
          <!-- Watermark step number in background -->
          <div class="absolute right-4 bottom-2 text-8xl font-black text-base-content/5 opacity-10 group-hover:scale-110 group-hover:text-primary/10 transition-all duration-500 select-none">
            {item.step}
          </div>
          
          <div class="card-body p-8 flex flex-col justify-between h-full relative z-10">
            <div>
              <!-- Step Header -->
              <div class="flex items-center justify-between mb-6">
                <!-- Icon with colorful gradient background -->
                <div class={`w-14 h-14 rounded-2xl bg-gradient-to-tr ${item.color} text-white flex items-center justify-center shadow-lg`}>
                  <span class="material-symbols-outlined text-2xl font-bold">
                    {item.icon}
                  </span>
                </div>
                <!-- Step Number Badge -->
                <span class="badge badge-lg bg-base-200 text-base-content/70 border-none font-extrabold rounded-full px-4">
                  Bước {item.step}
                </span>
              </div>
              
              <h3 class="card-title text-xl font-bold text-base-content mb-3 group-hover:text-primary transition-colors">
                {item.title}
              </h3>
              <p class="text-sm text-base-content/70 leading-relaxed font-medium">
                {item.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
