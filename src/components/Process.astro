---
const steps = [
  {
    step: "Bước 1",
    title: "Tiếp nhận & Tư vấn",
    desc: "Lắng nghe nhu cầu của khách hàng, phân tích đối thủ cạnh tranh và tư vấn gói thiết kế tối ưu nhất phù hợp ngân sách.",
    delay: "0ms"
  },
  {
    step: "Bước 2",
    title: "Trao đổi ý tưởng",
    desc: "Thu thập thông tin thương hiệu, thảo luận ý tưởng layout UI/UX và thống nhất sơ đồ cấu trúc của trang web.",
    delay: "100ms"
  },
  {
    step: "Bước 3",
    title: "Ký kết hợp đồng",
    desc: "Thống nhất chi phí, điều khoản dịch vụ và tiến hành ký kết hợp đồng chính thức (đặt cọc trước 80%).",
    delay: "200ms"
  },
  {
    step: "Bước 4",
    title: "Triển khai kỹ thuật",
    desc: "Đội ngũ lập trình viên tiến hành code giao diện, lập trình tính năng và tối ưu hóa tốc độ load trang trong vòng 20 ngày.",
    delay: "300ms"
  },
  {
    step: "Bước 5",
    title: "Gửi demo & Căn chỉnh",
    desc: "Gửi bản demo chạy thử cho khách hàng trải nghiệm, tiếp nhận phản hồi và tiến hành tinh chỉnh giao diện hoàn hảo.",
    delay: "400ms"
  },
  {
    step: "Bước 6",
    title: "Bàn giao & Bảo hành",
    desc: "Bàn giao mã nguồn, hướng dẫn quản trị web chi tiết, tiến hành thanh lý hợp đồng và kích hoạt chế độ bảo hành dài hạn.",
    delay: "500ms"
  }
];
---

<section
  id="process"
  class="py-section-padding-mobile md:py-section-padding-desktop px-6 sm:px-8 md:px-12 lg:px-16 bg-gradient-to-br from-surface-container-low to-surface relative overflow-hidden"
>
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-80 h-80 bg-primary/5 top-[20%] left-[-100px]" style="animation-duration: 25s;"></div>
    <div class="floating-blob w-80 h-80 bg-vibrant-blue/5 bottom-[20%] right-[-100px]" style="animation-duration: 20s; animation-delay: -5s;"></div>
  </div>

  <div class="max-w-container-max mx-auto relative z-10">
    <div
      class="text-center mb-24 space-y-4 scroll-animate fade-in-up"
    >
      <div class="inline-flex items-center gap-2 bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase">
          Quy trình làm việc
        </p>
      </div>
      <h2 class="text-headline-lg font-headline-lg text-deep-navy">
        Quy trình Thiết Kế Web Chuyên Nghiệp
      </h2>
      <p
        class="text-body-lg font-body-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed"
      >
        Thiết kế web đẹp - chuyên nghiệp - hiện đại - nhanh chóng - chi phí hợp lý. Luôn đồng hành mang lại hiệu quả kinh doanh cao nhất.
      </p>
    </div>
    
    <!-- Timeline Wrapper -->
    <div class="relative w-full max-w-4xl mx-auto pl-8 lg:pl-0">
      <!-- Vertical Central Line -->
      <div class="timeline-line"></div>
      
      <div class="space-y-12 lg:space-y-16">
        {steps.map((item, idx) => (
          <div 
            class={`relative flex flex-col lg:flex-row items-start lg:items-center w-full group scroll-animate ${
              idx % 2 === 0 ? 'fade-in-left' : 'fade-in-right lg:flex-row-reverse'
            }`}
            style={`transition-delay: ${item.delay}`}
          >
            <!-- Timeline central Node -->
            <div 
              class="absolute left-[-26px] lg:left-1/2 lg:-translate-x-1/2 w-10 h-10 rounded-full bg-white border-4 border-primary flex items-center justify-center shadow-md z-20 group-hover:scale-110 group-hover:border-vibrant-blue transition-all duration-300"
            >
              <span class="text-xs font-bold text-primary group-hover:text-vibrant-blue transition-colors">
                {idx + 1}
              </span>
            </div>
            
            <!-- Timeline Content Card -->
            <div class={`w-full lg:w-[45%] lg:px-4 ${
              idx % 2 === 0 ? 'lg:text-right' : 'lg:text-left'
            }`}>
              <div 
                class="glass-premium glowing-card rounded-2xl p-6 hover:shadow-lg transition-all duration-500 hover:-translate-y-1 bg-white/50"
              >
                <span class="text-xs font-extrabold text-primary tracking-widest uppercase block mb-1">
                  {item.step}
                </span>
                <h3 class="text-lg font-black text-deep-navy mb-2">
                  {item.title}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed">
                  {item.desc}
                </p>
              </div>
            </div>
            
            <!-- Empty column space to push content to one side on desktop -->
            <div class="hidden lg:block lg:w-[45%]"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
