---
const plans = [
  {
    name: "Cá nhân",
    price: "2.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (1 cái)",
      "Cập nhật nội dung miễn phí (2 bài)"
    ],
    delay: "0ms",
    discount: "Save 23%",
    popular: false
  },
  {
    name: "Khởi nghiệp",
    price: "4.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (2 cái)",
      "Cập nhật nội dung miễn phí (3 bài)"
    ],
    delay: "100ms",
    discount: "Save 23%",
    popular: false
  },
  {
    name: "Chuyên nghiệp",
    price: "6.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (3 cái)",
      "Cập nhật nội dung miễn phí (4 bài)"
    ],
    delay: "200ms",
    discount: "Hot Deal",
    popular: true // Nổi bật gói chuyên nghiệp
  },
  {
    name: "Doanh nghiệp",
    price: "8.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (4 cái)",
      "Cập nhật nội dung miễn phí (5 bài)"
    ],
    delay: "300ms",
    discount: "Save 23%",
    popular: false
  }
];
---

<section
  id="pricing"
  class="py-20 md:py-32 px-6 sm:px-8 md:px-12 lg:px-16 relative bg-base-100 overflow-hidden"
>
  <!-- Background Ambient Glows -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-[500px] h-[500px] bg-primary/5 top-[-100px] left-[10%]" style="animation-duration: 25s;"></div>
    <div class="floating-blob w-80 h-80 bg-secondary/5 bottom-12 right-10" style="animation-duration: 18s; animation-delay: -4s;"></div>
  </div>

  <div class="max-w-[1280px] mx-auto relative z-10">
    <div
      class="text-center mb-20 space-y-4 scroll-animate fade-in-up"
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20">
        <p class="text-xs font-bold text-primary tracking-widest uppercase">
          Bảng Giá Dịch Vụ
        </p>
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-base-content">
        Lựa chọn gói web tối ưu cho bạn
      </h2>
      <p
        class="text-base sm:text-lg text-base-content/70 max-w-2xl mx-auto leading-relaxed"
      >
        Hơn 10 năm hoạt động về dịch vụ Thiết kế Web Nha Trang, chúng tôi tự
        tin giúp quý khách sở hữu website chuyên nghiệp để quảng bá thương hiệu.
      </p>
    </div>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 items-stretch">
      {plans.map((plan) => (
        <div
          class={`card rounded-2xl sm:rounded-3xl bg-base-100 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 scroll-animate fade-in-up relative cursor-pointer border ${
            plan.popular 
              ? 'border-primary shadow-primary/10 ring-2 ring-primary/20 lg:scale-[1.03]' 
              : 'border-base-200/50'
          }`}
          style={`transition-delay: ${plan.delay}`}
        >
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white text-[9px] sm:text-xs font-extrabold px-2 sm:px-4 py-1 rounded-full shadow-md select-none uppercase z-20">
              KHUYÊN DÙNG
            </div>
          )}

          {plan.discount && !plan.popular && (
            <div
              class="absolute top-2 right-2 sm:top-3 sm:right-3 badge badge-secondary font-bold text-[8px] sm:text-[10px] px-1.5 sm:px-2.5 py-0.5 sm:py-1"
            >
              {plan.discount}
            </div>
          )}
          
          <div class="card-body p-4 sm:p-8 flex flex-col justify-between h-full">
            <div>
              <span class="text-[9px] sm:text-xs font-bold text-base-content/50 uppercase tracking-widest block mb-1">
                Gói dịch vụ
              </span>
              <h3 class="text-base sm:text-xl font-black text-base-content mb-2 sm:mb-4">
                {plan.name}
              </h3>
              
              <div class="flex items-baseline mb-3 sm:mb-6">
                <span class="text-lg sm:text-3xl font-black text-primary tracking-tight">
                  {plan.price}
                </span>
                <span class="text-[9px] sm:text-xs font-extrabold text-base-content/60 ml-1 sm:ml-2 uppercase tracking-wide">
                  VNĐ
                </span>
              </div>
              
              <div class="border-t border-base-200 my-4 sm:my-6"></div>
              
              <ul class="space-y-2 sm:space-y-4 mb-4 sm:mb-8 text-base-content/80 text-[11px] sm:text-sm font-semibold">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2 sm:gap-3 group/item">
                    <span class="text-primary text-[9px] sm:text-xs transition-all duration-500 group-hover/item:rotate-180 group-hover/item:scale-125 block shrink-0 mt-1 select-none">✦</span> 
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <a
              class={`btn btn-sm sm:btn-md rounded-full font-bold text-[10px] sm:text-xs tracking-wider transition-all duration-300 w-full mt-auto ${
                plan.popular 
                  ? 'btn-primary text-white hover:shadow-lg shadow-md border-none' 
                  : 'btn-outline btn-primary hover:text-white'
              }`}
              href="https://zalo.me/0933663112"
              style={plan.popular ? "background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-vibrant-blue) 100%);" : ""}
            >
              ĐĂNG KÝ NGAY
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
