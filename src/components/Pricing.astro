---
const plans = [
  {
    name: "Cá nhân",
    price: "2.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (1 cái)",
      "Cập nhật nội dung miễn phí (2 bài)"
    ],
    delay: "0ms",
    discount: "Save 23%",
    popular: false
  },
  {
    name: "Khởi nghiệp",
    price: "4.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (2 cái)",
      "Cập nhật nội dung miễn phí (3 bài)"
    ],
    delay: "100ms",
    discount: "Save 23%",
    popular: false
  },
  {
    name: "Chuyên nghiệp",
    price: "6.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (3 cái)",
      "Cập nhật nội dung miễn phí (4 bài)"
    ],
    delay: "200ms",
    discount: "Save 23%",
    popular: true // Nổi bật gói chuyên nghiệp
  },
  {
    name: "Doanh nghiệp",
    price: "8.000.000",
    features: [
      "Tặng tên miền .COM quốc tế",
      "Máy chủ băng thông không giới hạn",
      "Hệ thống Email tên miền (4 cái)",
      "Cập nhật nội dung miễn phí (5 bài)"
    ],
    delay: "300ms",
    discount: "Save 23%",
    popular: false
  }
];
---

<section
  id="pricing"
  class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative bg-surface overflow-hidden"
>
  <!-- Background Ambient Glows -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-[500px] h-[500px] bg-primary-container/10 top-[-100px] left-[10%]" style="animation-duration: 25s;"></div>
    <div class="floating-blob w-80 h-80 bg-vibrant-blue/15 bottom-12 right-10" style="animation-duration: 18s; animation-delay: -4s;"></div>
  </div>

  <div class="max-w-container-max mx-auto relative z-10">
    <div
      class="text-center mb-20 space-y-4 scroll-animate fade-in-up is-visible"
    >
      <div class="inline-flex items-center gap-2 bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase">
          Bảng Giá Dịch Vụ
        </p>
      </div>
      <h2 class="text-headline-lg font-headline-lg text-deep-navy">
        Lựa chọn gói web tối ưu cho bạn
      </h2>
      <p
        class="text-body-lg font-body-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed"
      >
        Hơn 10 năm hoạt động về dịch vụ Thiết kế Web Nha Trang, chúng tôi tự
        tin giúp quý khách sở hữu website chuyên nghiệp để quảng bá thương hiệu.
      </p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 items-stretch">
      {plans.map((plan) => (
        <div
          class={`glass-premium glowing-card rounded-3xl p-6 md:p-8 flex flex-col justify-between hover:shadow-xl transition-all duration-500 scroll-animate fade-in-up is-visible relative hover:-translate-y-2 cursor-pointer ${
            plan.popular ? 'border-2 border-primary/60 shadow-lg shadow-primary-container/10 lg:scale-[1.03]' : ''
          }`}
          style={`transition-delay: ${plan.delay}`}
        >
          <!-- Special Popular Tag -->
          {plan.popular && (
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-gradient-primary text-on-primary text-xxs font-black px-4 py-1 rounded-full uppercase tracking-wider shadow-md border border-white/20 select-none">
              Phổ biến nhất
            </div>
          )}

          {plan.discount && (
            <div
              class="absolute top-4 right-4 bg-action-orange text-white text-xxs font-black px-2.5 py-1 rounded-full shadow-sm select-none"
            >
              {plan.discount}
            </div>
          )}
          
          <div>
            <span class="text-xs font-bold text-on-surface-variant/70 uppercase tracking-widest block mb-1">
              Gói dịch vụ
            </span>
            <h3 class="text-headline-md font-headline-md text-deep-navy font-bold mb-4">
              {plan.name}
            </h3>
            
            <div class="flex items-baseline mb-8">
              <span class="text-3xl md:text-4xl font-black text-primary tracking-tight">
                {plan.price}
              </span>
              <span class="text-xs font-bold text-on-surface-variant/80 ml-2 uppercase tracking-wide">
                VNĐ / trọn gói
              </span>
            </div>
            
            <div class="border-t border-outline-variant/30 my-6"></div>
            
            <ul class="space-y-4 mb-8 text-on-surface-variant text-sm font-medium">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 group/item">
                  <span class="text-primary text-sm transition-transform duration-300 group-hover/item:translate-x-1">➤</span> 
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <a
            class={`block w-full text-center py-3.5 rounded-full font-bold text-xs tracking-wider transition-all duration-300 border shine-effect cursor-pointer ${
              plan.popular
                ? 'bg-gradient-primary text-on-primary border-white/20 shadow-md shadow-primary-container/20 hover:shadow-lg'
                : 'bg-white/50 text-primary border-primary/20 hover:bg-primary hover:text-white hover:border-transparent'
            }`}
            href="https://zalo.me/0933663112"
          >
            ĐĂNG KÝ NGAY
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
