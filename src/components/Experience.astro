---
---

<section
  class="py-20 md:py-32 px-6 sm:px-8 md:px-12 lg:px-16 bg-base-100 relative overflow-hidden"
>
  <!-- Background Blob -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-72 h-72 bg-primary/5 -bottom-10 left-[-50px]" style="animation-duration: 20s;"></div>
  </div>

  <div class="max-w-[1280px] mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <!-- Images Grid (With 3D Parallax Hover effect) -->
      <div
        class="relative grid grid-cols-2 gap-4 scroll-animate fade-in-left pb-8 lg:pb-0 group cursor-pointer"
      >
        <!-- Left Image -->
        <div class="relative overflow-hidden rounded-2xl shadow-xl transform translate-y-8 group-hover:translate-y-12 group-hover:scale-[1.02] transition-all duration-700 ease-out border border-base-200/50">
          <img
            alt="Đội ngũ thiết kế web chuyên nghiệp của Web Nha Trang"
            class="object-cover w-full h-[250px] sm:h-[350px] hover:scale-105 transition-transform duration-700"
            src="/images/team-working.png"
          />
        </div>
        <!-- Right Image -->
        <div class="relative overflow-hidden rounded-2xl shadow-xl transform -translate-y-4 group-hover:-translate-y-8 group-hover:scale-[1.02] transition-all duration-700 ease-out border border-base-200/50">
          <img
            alt="Góc làm việc hiện đại"
            class="object-cover w-full h-[250px] sm:h-[350px] hover:scale-105 transition-transform duration-700"
            src="/images/workspace-setup.png"
          />
        </div>
        
        <!-- Decorative circular blur -->
        <div
          class="absolute -z-10 -bottom-8 -left-8 w-64 h-64 bg-primary/10 rounded-full blur-3xl opacity-70 group-hover:scale-110 transition-transform duration-700"
        ></div>
      </div>
      
      <!-- Content Column -->
      <div class="space-y-6 scroll-animate fade-in-right">
        <div class="inline-flex items-center gap-2 bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20">
          <p class="text-xs font-bold text-primary tracking-widest uppercase">
            Hành Trình & Phát Triển
          </p>
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-base-content leading-tight">
          Hơn 10 năm cung cấp dịch vụ thiết kế web tại Nha Trang
        </h2>
        <p
          class="text-base text-base-content/80 leading-relaxed"
        >
          Tự hào là đơn vị dẫn đầu công nghệ website tại Nha Trang, chúng
          tôi cam kết với khách hàng những sản phẩm thực hiện đều hoàn hảo,
          giá cạnh tranh với thị trường hiện nay. Rất sẵn sàng khi tư vấn hỗ
          trợ quý khách hàng trong hôm nay !
        </p>
        
        <!-- Experience stats counters using DaisyUI stats -->
        <div class="stats stats-vertical sm:stats-horizontal shadow bg-base-200/50 w-full border border-base-300/30 my-6">
          <div class="stat p-4 sm:p-6">
            <div class="stat-value text-primary text-3xl font-black">10+</div>
            <div class="stat-title text-base-content/70 font-semibold text-xs mt-1">Năm kinh nghiệm</div>
          </div>
          <div class="stat p-4 sm:p-6 border-t sm:border-t-0 sm:border-l border-base-300/50">
            <div class="stat-value text-primary text-3xl font-black">500+</div>
            <div class="stat-title text-base-content/70 font-semibold text-xs mt-1">Khách hàng tin dùng</div>
          </div>
          <div class="stat p-4 sm:p-6 border-t sm:border-t-0 sm:border-l border-base-300/50">
            <div class="stat-value text-primary text-3xl font-black">100%</div>
            <div class="stat-title text-base-content/70 font-semibold text-xs mt-1">Hài lòng tuyệt đối</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 pt-2">
          <a
            class="btn btn-primary rounded-full px-8 h-12 text-white font-bold text-xs tracking-wider border-none hover:shadow-lg transition-all flex items-center gap-2 shine-effect cursor-pointer"
            href="https://zalo.me/0933663112"
            style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-vibrant-blue) 100%);"
          >
            <span class="material-symbols-outlined text-sm">call</span>
            LIÊN HỆ NGAY
          </a>
          <a
            class="btn btn-outline border-base-300 text-base-content hover:bg-base-200 px-8 h-12 rounded-full font-bold text-xs tracking-wider transition-all flex items-center gap-2 bg-transparent cursor-pointer"
            href="https://www.kieugiamedia.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="material-symbols-outlined text-sm">info</span>
            TÌM HIỂU THÊM
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
