---
---

<!-- Floating Contact Elements -->
<div class="fixed bottom-8 right-8 flex flex-col gap-4 z-50">
  <!-- Phone call button with sonar pulse -->
  <a
    class="w-14 h-14 bg-red-500 rounded-full flex items-center justify-center shadow-lg shadow-red-500/30 hover:scale-110 hover:rotate-6 transition-all duration-300 relative group"
    href="tel:0933663112"
    aria-label="Gọi điện trực tiếp"
  >
    <div class="sonar-wave text-red-500"></div>
    <span class="absolute -left-28 bg-deep-navy text-white text-xs px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap shadow-md">
      Gọi: 0933.663.112
    </span>
    <span class="material-symbols-outlined text-white text-2xl relative z-10" data-icon="call">
      call
    </span>
  </a>

  <!-- Zalo button with sonar pulse -->
  <a
    class="w-14 h-14 bg-blue-500 rounded-full flex items-center justify-center shadow-lg shadow-blue-500/30 hover:scale-110 hover:-rotate-6 transition-all duration-300 relative group"
    href="https://zalo.me/0933663112"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Liên hệ qua Zalo"
  >
    <div class="sonar-wave text-blue-500" style="animation-delay: 0.5s;"></div>
    <span class="absolute -left-24 bg-deep-navy text-white text-xs px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap shadow-md">
      Chat Zalo ngay
    </span>
    <span class="text-white font-bold text-xl relative z-10 select-none">Z</span>
  </a>

  <!-- Messenger button with sonar pulse -->
  <a
    class="w-14 h-14 bg-gradient-to-tr from-blue-600 to-blue-400 rounded-full flex items-center justify-center shadow-lg shadow-blue-500/30 hover:scale-110 hover:rotate-6 transition-all duration-300 relative group"
    href="https://m.me/webnhatrang2023"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Liên hệ qua Messenger Facebook"
  >
    <div class="sonar-wave text-blue-600" style="animation-delay: 1s;"></div>
    <span class="absolute -left-28 bg-deep-navy text-white text-xs px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap shadow-md">
      Chat Messenger
    </span>
    <span class="material-symbols-outlined text-white text-2xl relative z-10" data-icon="forum">
      forum
    </span>
  </a>
</div>
