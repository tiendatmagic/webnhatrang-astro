---
---

<nav
  id="main-nav"
  class="fixed top-6 left-1/2 -translate-x-1/2 w-[92%] max-w-container-max z-50 flex justify-between items-center px-6 md:px-10 py-3 bg-white md:bg-white/60 md:backdrop-blur-xl border border-white/40 rounded-full shadow-lg transition-all duration-500 ease-out"
>
  <!-- Logo -->
  <div class="flex items-center gap-2">
    <a href="#" class="flex items-center gap-2 hover:scale-105 transition-transform duration-300">
      <img
        src="/logowebsite.png"
        alt="WEB NHA TRANG Logo"
        class="w-10 h-10 md:w-11 md:h-11 object-contain"
      />
    </a>
  </div>
  
  <!-- Desktop menu -->
  <div class="hidden md:flex items-center space-x-8">
    <a
      class="text-primary font-bold text-sm tracking-wide relative py-1 after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-primary after:rounded-full"
      href="#"
    >
      Trang chủ
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-medium text-sm tracking-wide transition-all relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:rounded-full hover:after:w-full after:transition-all after:duration-300"
      href="#services"
    >
      Dịch vụ
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-medium text-sm tracking-wide transition-all relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:rounded-full hover:after:w-full after:transition-all after:duration-300"
      href="#pricing"
    >
      Bảng giá
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-medium text-sm tracking-wide transition-all relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:rounded-full hover:after:w-full after:transition-all after:duration-300"
      href="#process"
    >
      Quy trình
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-medium text-sm tracking-wide transition-all relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:rounded-full hover:after:w-full after:transition-all after:duration-300"
      href="#contact"
    >
      Liên hệ
    </a>
  </div>

  <!-- Action button & Mobile Toggle -->
  <div class="flex items-center gap-4">
    <a
      class="hidden sm:inline-block bg-gradient-primary text-on-primary px-6 py-2.5 rounded-full font-bold text-xs tracking-wider hover:shadow-lg hover:shadow-primary-container/20 transition-all duration-300 transform hover:scale-105 border border-white/20 shine-effect cursor-pointer"
      href="https://zalo.me/0933663112"
    >
      BẮT ĐẦU NGAY
    </a>
    
    <!-- Mobile Hamburger Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-primary hover:text-primary/80 focus:outline-none w-10 h-10 flex items-center justify-center rounded-full bg-black/5 active:bg-black/10 hover:bg-black/10 transition-colors"
      aria-label="Toggle Menu"
    >
      <span class="material-symbols-outlined text-2xl select-none" id="menu-icon">menu</span>
    </button>
  </div>

  <!-- Mobile Dropdown Menu (Opaque Background to prevent text overlapping) -->
  <div
    id="mobile-menu"
    class="hidden absolute top-[115%] left-0 w-full bg-white border border-outline-variant/30 rounded-3xl flex flex-col p-6 space-y-4 shadow-2xl md:hidden transition-all duration-300 z-50"
  >
    <a
      class="text-primary font-bold text-base border-l-4 border-primary pl-3 py-1.5"
      href="#"
    >
      Trang chủ
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-semibold text-base pl-3 py-1.5"
      href="#services"
    >
      Dịch vụ
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-semibold text-base pl-3 py-1.5"
      href="#pricing"
    >
      Bảng giá
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-semibold text-base pl-3 py-1.5"
      href="#process"
    >
      Quy trình
    </a>
    <a
      class="text-on-surface-variant hover:text-primary font-semibold text-base pl-3 py-1.5"
      href="#contact"
    >
      Liên hệ
    </a>
    <a
      class="bg-gradient-primary text-on-primary text-center py-3.5 rounded-full font-bold text-sm tracking-wider uppercase shadow-md hover:shadow-lg cursor-pointer transition-all duration-300 shine-effect"
      href="https://zalo.me/0933663112"
    >
      Bắt đầu ngay
    </a>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  if (mobileMenuBtn && mobileMenu && menuIcon) {
    mobileMenuBtn.addEventListener('click', () => {
      const isHidden = mobileMenu.classList.contains('hidden');
      if (isHidden) {
        mobileMenu.classList.remove('hidden');
        menuIcon.textContent = 'close';
      } else {
        mobileMenu.classList.add('hidden');
        menuIcon.textContent = 'menu';
      }
    });

    const mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuIcon.textContent = 'menu';
      });
    });
  }

  // Scroll shrink navbar with responsive classes
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (nav) {
      if (window.scrollY > 50) {
        nav.classList.remove('top-6', 'py-3', 'bg-white', 'md:bg-white/60');
        nav.classList.add('top-3', 'py-2', 'bg-white', 'md:bg-white/85', 'shadow-xl');
      } else {
        nav.classList.remove('top-3', 'py-2', 'bg-white', 'md:bg-white/85', 'shadow-xl');
        nav.classList.add('top-6', 'py-3', 'bg-white', 'md:bg-white/60');
      }
    }
  });
</script>
