      </button>
      <ul
        id="mobile-menu"
        tabindex="0"
        class="menu menu-sm dropdown-content mt-3 z-[1] p-3 shadow-2xl bg-base-100 rounded-box w-64 border border-base-200/50 hidden"
      >
        <li>
          <a class="flex items-center gap-3 text-primary font-bold py-2.5 bg-primary/5 rounded-lg" href="#">
            <span class="material-symbols-outlined text-[20px]">home</span>
            <span>Trang chủ</span>
          </a>
        </li>
        <li>
          <a class="flex items-center gap-3 py-2.5 hover:text-primary transition-all rounded-lg" href="#services">
            <span class="material-symbols-outlined text-[20px]">design_services</span>
            <span>Dịch vụ</span>
          </a>
        </li>
        <li>
          <a class="flex items-center gap-3 py-2.5 hover:text-primary transition-all rounded-lg" href="#pricing">
            <span class="material-symbols-outlined text-[20px]">payments</span>
            <span>Bảng giá</span>
          </a>
        </li>
        <li>
          <a class="flex items-center gap-3 py-2.5 hover:text-primary transition-all rounded-lg" href="#process">
            <span class="material-symbols-outlined text-[20px]">account_tree</span>
            <span>Quy trình</span>
          </a>
        </li>
        <li>
          <a class="flex items-center gap-3 py-2.5 hover:text-primary transition-all rounded-lg" href="#contact">
            <span class="material-symbols-outlined text-[20px]">chat</span>
            <span>Liên hệ</span>
          </a>
        </li>
        <li class="mt-3">
          <a
            class="btn btn-primary btn-sm rounded-full text-white font-bold text-center flex items-center justify-center py-2"
            href="https://zalo.me/0933663112"
          >
            BẮT ĐẦU NGAY
          </a>
        </li>
      </ul>
    </div>

    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 hover:scale-105 transition-transform duration-300 ml-2 lg:ml-0">
      <img
        src="/logo.jpg"
        alt="WEB NHA TRANG Logo"
        class="w-10 h-10 md:w-11 md:h-11 rounded-full object-contain border border-primary/20 shadow-sm"
      />
      <span class="font-black text-lg md:text-xl tracking-tight bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
        WEB NHA TRANG
      </span>
    </a>
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-2 font-semibold text-[15px]">
      <li>
        <a class="flex items-center gap-1.5 text-primary active:bg-primary/10 rounded-full px-4 py-2" href="#">
          <span class="material-symbols-outlined text-[18px]">home</span>
          <span>Trang chủ</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all" href="#services">
          <span class="material-symbols-outlined text-[18px]">design_services</span>
          <span>Dịch vụ</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all" href="#pricing">
          <span class="material-symbols-outlined text-[18px]">payments</span>
          <span>Bảng giá</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all" href="#process">
          <span class="material-symbols-outlined text-[18px]">account_tree</span>
          <span>Quy trình</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all" href="#contact">
          <span class="material-symbols-outlined text-[18px]">chat</span>
          <span>Liên hệ</span>
        </a>
      </li>
    </ul>
  </div>

  <div class="navbar-end">
    <a
      class="btn btn-primary text-white rounded-full font-bold px-6 border-none hover:shadow-lg shadow-md transition-all duration-300 hover:scale-105"
      href="https://zalo.me/0933663112"
      style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-vibrant-blue) 100%);"
    >
      BẮT ĐẦU NGAY
    </a>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");

  if (mobileMenuBtn && mobileMenu && menuIcon) {
    mobileMenuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = mobileMenu.classList.contains("hidden");
      if (isHidden) {
        mobileMenu.classList.remove("hidden");
        menuIcon.textContent = "close";
      } else {
        mobileMenu.classList.add("hidden");
        menuIcon.textContent = "menu";
      }
    });

    // Close when clicking outside
    document.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      menuIcon.textContent = "menu";
    });

    const mobileLinks = mobileMenu.querySelectorAll("a");
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        menuIcon.textContent = "menu";
      });
    });
  }

  // Scroll shrink navbar with responsive classes
  const nav = document.getElementById("main-nav");
  window.addEventListener("scroll", () => {
    if (nav) {
      if (window.scrollY > 50) {
        nav.classList.remove("top-6", "bg-white/70");
        nav.classList.add("top-3", "bg-white/95", "shadow-xl");
      } else {
        nav.classList.remove("top-3", "bg-white/95", "shadow-xl");
        nav.classList.add("top-6", "bg-white/70");
      }
    }
  });
</script>
