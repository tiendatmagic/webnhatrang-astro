<nav
  id="main-nav"
  class="navbar fixed top-6 inset-x-6 sm:inset-x-8 md:inset-x-12 lg:inset-x-16 mx-auto w-auto max-w-[1280px] z-50 bg-white/70 backdrop-blur-xl border border-white/40 rounded-full shadow-lg transition-all duration-500 ease-out px-4 md:px-8"
>
  <div class="navbar-start flex-1 min-w-0">
    <!-- Hamburger Button for mobile drawer -->
    <button
      id="mobile-menu-btn"
      class="btn btn-ghost btn-circle text-primary hover:bg-primary/10 lg:hidden shrink-0"
      aria-label="Open Menu"
    >
      <span class="material-symbols-outlined text-2xl select-none">menu</span>
    </button>

    <!-- Logo -->
    <a
      href="#"
      class="flex items-center gap-2 hover:scale-105 transition-transform duration-300 ml-2 lg:ml-0 shrink-0 whitespace-nowrap"
    >
      <img
        src="/logo.jpg"
        alt="WEB NHA TRANG Logo"
        class="w-10 h-10 md:w-11 md:h-11 rounded-full object-contain border border-primary/20 shadow-sm"
      />
      <span
        class="font-black text-lg md:text-xl tracking-tight bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent shrink-0 whitespace-nowrap"
      >
        WEB NHA TRANG
      </span>
    </a>
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-2 font-semibold text-[15px]">
      <li>
        <a
          class="flex items-center gap-1.5 text-primary active:bg-primary/10 rounded-full px-4 py-2"
          href="#"
        >
          <span class="material-symbols-outlined text-[18px]">home</span>
          <span>Trang chủ</span>
        </a>
      </li>
      <li>
        <a
          class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all"
          href="#services"
        >
          <span class="material-symbols-outlined text-[18px]"
            >design_services</span
          >
          <span>Dịch vụ</span>
        </a>
      </li>
      <li>
        <a
          class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all"
          href="#pricing"
        >
          <span class="material-symbols-outlined text-[18px]">payments</span>
          <span>Bảng giá</span>
        </a>
      </li>
      <li>
        <a
          class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all"
          href="#process"
        >
          <span class="material-symbols-outlined text-[18px]">account_tree</span
          >
          <span>Quy trình</span>
        </a>
      </li>
      <li>
        <a
          class="flex items-center gap-1.5 hover:text-primary hover:bg-primary/5 active:bg-primary/10 rounded-full px-4 py-2 transition-all"
          href="#contact"
        >
          <span class="material-symbols-outlined text-[18px]">chat</span>
          <span>Liên hệ</span>
        </a>
      </li>
    </ul>
  </div>

  <div class="navbar-end flex-none sm:flex-1">
    <a
      class="btn btn-primary text-white rounded-full font-bold px-6 border-none hover:shadow-lg shadow-md transition-all duration-300 hover:scale-105 hidden sm:inline-flex"
      href="https://zalo.me/0933663112"
      style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-vibrant-blue) 100%);"
    >
      BẮT ĐẦU NGAY
    </a>
  </div>
</nav>

<!-- Mobile Slide-over Drawer Menu -->
<div id="mobile-drawer" class="fixed inset-0 z-[100] pointer-events-none">
  <!-- Dark Backdrop Overlay -->
  <div
    id="drawer-overlay"
    class="fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-out pointer-events-none"
  >
  </div>

  <!-- Sidebar Panel -->
  <div
    id="drawer-panel"
    class="fixed top-0 left-0 bottom-0 w-80 max-w-[85vw] bg-base-100 shadow-2xl flex flex-col p-6 z-50 transform -translate-x-full transition-transform duration-300 ease-out pointer-events-auto"
  >
    <!-- Drawer Header -->
    <div
      class="flex items-center justify-between border-b border-base-200 pb-4 mb-6"
    >
      <div class="flex items-center gap-2">
        <img
          src="/logo.jpg"
          alt="WEB NHA TRANG Logo"
          class="w-10 h-10 rounded-full object-contain border border-primary/20"
        />
        <div>
          <h4 class="font-black text-sm text-primary">WEB NHA TRANG</h4>
          <p
            class="text-[9px] text-base-content/50 uppercase tracking-widest font-bold"
          >
            Chuyên nghiệp - Uy tín
          </p>
        </div>
      </div>
      <button
        id="drawer-close-btn"
        class="btn btn-ghost btn-circle btn-sm border border-base-200 flex items-center justify-center text-base-content/70 hover:text-primary"
        aria-label="Close Menu"
      >
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>

    <!-- Drawer Navigation Links -->
    <div class="flex-1 overflow-y-auto">
      <ul
        class="menu p-0 gap-2 font-bold text-[16px] text-base-content/85 w-full"
      >
        <li>
          <a
            class="flex items-center gap-3 py-3 text-primary bg-primary/5 rounded-xl"
            href="#"
          >
            <span class="material-symbols-outlined text-[22px]">home</span>
            <span>Trang chủ</span>
          </a>
        </li>
        <li>
          <a
            class="flex items-center gap-3 py-3 hover:text-primary hover:bg-primary/5 rounded-xl transition-all"
            href="#services"
          >
            <span
              class="material-symbols-outlined text-[22px] text-base-content/60"
              >design_services</span
            >
            <span>Dịch vụ</span>
          </a>
        </li>
        <li>
          <a
            class="flex items-center gap-3 py-3 hover:text-primary hover:bg-primary/5 rounded-xl transition-all"
            href="#pricing"
          >
            <span
              class="material-symbols-outlined text-[22px] text-base-content/60"
              >payments</span
            >
            <span>Bảng giá</span>
          </a>
        </li>
        <li>
          <a
            class="flex items-center gap-3 py-3 hover:text-primary hover:bg-primary/5 rounded-xl transition-all"
            href="#process"
          >
            <span
              class="material-symbols-outlined text-[22px] text-base-content/60"
              >account_tree</span
            >
            <span>Quy trình</span>
          </a>
        </li>
        <li>
          <a
            class="flex items-center gap-3 py-3 hover:text-primary hover:bg-primary/5 rounded-xl transition-all"
            href="#contact"
          >
            <span
              class="material-symbols-outlined text-[22px] text-base-content/60"
              >chat</span
            >
            <span>Liên hệ</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Drawer Footer / CTA button -->
    <div class="border-t border-base-200 pt-6 mt-auto">
      <a
        class="btn btn-primary rounded-full w-full py-3 h-auto text-white font-bold tracking-wide flex items-center justify-center gap-2 border-none shadow-lg shadow-primary/20"
        href="https://zalo.me/0933663112"
        style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-vibrant-blue) 100%);"
      >
        <span class="material-symbols-outlined text-lg">chat</span>
        LIÊN HỆ TƯ VẤN BÁO GIÁ
      </a>
    </div>
  </div>
</div>

<script>
  // Mobile drawer controls
  const openDrawerBtn = document.getElementById("mobile-menu-btn");
  const closeDrawerBtn = document.getElementById("drawer-close-btn");
  const drawerOverlay = document.getElementById("drawer-overlay");
  const drawerPanel = document.getElementById("drawer-panel");
  const mobileDrawer = document.getElementById("mobile-drawer");

  function openDrawer() {
    if (mobileDrawer && drawerOverlay && drawerPanel) {
      mobileDrawer.classList.remove("pointer-events-none");
      drawerOverlay.classList.remove("pointer-events-none", "opacity-0");
      drawerOverlay.classList.add("opacity-100");
      drawerPanel.classList.remove("-translate-x-full");
      drawerPanel.classList.add("translate-x-0");
      document.body.style.overflow = "hidden"; // Prevent background scroll
    }
  }

  function closeDrawer() {
    if (mobileDrawer && drawerOverlay && drawerPanel) {
      drawerOverlay.classList.remove("opacity-100");
      drawerOverlay.classList.add("opacity-0", "pointer-events-none");
      drawerPanel.classList.remove("translate-x-0");
      drawerPanel.classList.add("-translate-x-full");
      mobileDrawer.classList.add("pointer-events-none");
      document.body.style.overflow = ""; // Restore scroll
    }
  }

  if (openDrawerBtn && closeDrawerBtn && drawerOverlay && drawerPanel) {
    openDrawerBtn.addEventListener("click", openDrawer);
    closeDrawerBtn.addEventListener("click", closeDrawer);
    drawerOverlay.addEventListener("click", closeDrawer);

    // Close drawer when clicking on menu links
    const drawerLinks = drawerPanel.querySelectorAll("ul.menu a");
    drawerLinks.forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });
  }

  // Scroll shrink navbar with responsive classes
  const nav = document.getElementById("main-nav");
  window.addEventListener("scroll", () => {
    if (nav) {
      if (window.scrollY > 50) {
        nav.classList.remove("top-6", "bg-white/70");
        nav.classList.add("top-3", "bg-white/95", "shadow-xl");
      } else {
        nav.classList.remove("top-3", "bg-white/95", "shadow-xl");
        nav.classList.add("top-6", "bg-white/70");
      }
    }
  });
</script>
