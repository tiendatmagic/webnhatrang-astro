---
---

<section
  id="contact"
  class="py-16 px-6 sm:px-8 md:px-12 lg:px-16 bg-white border-t border-outline-variant/20 relative"
>
  <div
    class="max-w-container-max mx-auto scroll-animate fade-in-up"
  >
    <div
      class="bg-primary/5 rounded-[2rem] p-8 md:p-12 flex flex-col lg:flex-row items-center justify-between gap-8 border border-primary/10"
    >
      <div class="max-w-2xl">
        <h2 class="text-headline-lg font-headline-lg text-deep-navy mb-4">
          Yêu cầu tư vấn
        </h2>
        <p class="text-body-lg font-body-lg text-on-surface-variant">
          Bạn muốn chúng tôi chủ động liên hệ. Hãy để lại số điện thoại,
          chúng tôi sẽ chủ động gọi cho bạn !
        </p>
      </div>
      <form
        class="w-full lg:w-auto flex flex-col md:flex-row gap-4 shrink-0"
        onsubmit="event.preventDefault(); alert('Cảm ơn bạn! Chúng tôi đã nhận được thông tin và sẽ liên hệ lại sớm nhất.'); this.reset();"
      >
        <input
          class="w-full md:w-64 bg-white border border-outline-variant/50 rounded-full px-6 py-4 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors shadow-sm"
          placeholder="Số điện thoại"
          type="tel"
          pattern="[0-9]{10,11}"
          required
        />
        <button
          class="bg-gradient-primary text-on-primary px-10 py-4 rounded-full font-bold hover:shadow-lg transition-all whitespace-nowrap cursor-pointer hover:scale-[1.02] duration-200"
          type="submit"
        >
          GỬI NGAY
        </button>
      </form>
    </div>
  </div>
</section>
