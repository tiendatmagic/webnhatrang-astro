---

<footer
  class="bg-surface border-t border-outline-variant/30 text-on-surface w-full py-16 px-6 sm:px-8 md:px-12 lg:px-16 flex flex-col items-center justify-center space-y-8 relative overflow-hidden"
>
  <div
    class="max-w-container-max mx-auto w-full grid grid-cols-1 lg:grid-cols-4 gap-12 items-center relative z-10"
  >
    <!-- Graphic Image Left -->
    <div class="lg:col-span-1 flex justify-center lg:justify-start">
      <img
        src="/logo.jpg"
        alt="Graphic Illustration"
        class="w-64 h-64 object-contain"
      />
    </div>

    <!-- Links & Company Info Right -->
    <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-12 w-full">
      <!-- Company Info -->
      <div class="space-y-4">
        <h3
          class="text-headline-md font-headline-md font-bold text-primary mb-6"
        >
          CÔNG TY TNHH WEB NHA TRANG
        </h3>
        <div class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-primary mt-1"
            data-icon="location_on"
          >
            location_on
          </span>
          <p class="text-body-md font-body-md text-on-surface-variant">
            Số 88 Tô Hiến Thành, Tân Lập,<br />TP Nha Trang, Tỉnh Khánh Hòa
          </p>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="call">
            call
          </span>
          <p class="text-body-md font-body-md text-on-surface-variant">
            093.366.3112 - 093.366.3112
          </p>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="mail">
            mail
          </span>
          <p class="text-body-md font-body-md text-on-surface-variant">
            info@webnhatrang.com
          </p>
        </div>
      </div>

      <!-- Information Links -->
      <div>
        <h4 class="text-headline-md font-headline-md text-deep-navy mb-6">
          Thông tin
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="#"
            >
              Giới thiệu công ty
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="#"
            >
              Thông tin đào tạo
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="#"
            >
              Thông tin chính sách
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="#"
            >
              Thông tin thanh toán
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="#"
            >
              Thông tin tuyển dụng
            </a>
          </li>
        </ul>
      </div>

      <!-- Services Links -->
      <div>
        <h4 class="text-headline-md font-headline-md text-deep-navy mb-6">
          Dịch vụ
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="https://webdalat.pys.vn/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Thiết kế Website Đà Lạt
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="https://www.webtuyhoa.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              Thiết kế Website Tuy Hòa
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="https://www.webphuyen.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              Thiết kế Website Phú Yên
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="https://www.webnhatrang.vn/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Thiết kế Website Nha Trang
            </a>
          </li>
          <li>
            <a
              class="text-body-md text-on-surface-variant hover:text-primary hover:underline transition-all duration-300"
              href="https://webcamranh.pys.vn/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Thiết kế Website Cam Ranh
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div
    class="w-full border-t border-outline-variant/30 pt-8 mt-8 text-center relative z-10"
  >
    <p class="text-body-md font-body-md text-on-surface-variant">
      © 2026 WEB NHA TRANG. Made with ❤️ in Nha Trang.
    </p>
  </div>
</footer>
