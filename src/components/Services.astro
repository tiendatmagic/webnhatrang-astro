---
const services = [
  {
    title: "Quản trị Website",
    icon: "settings",
    price: "1.500.000 vnđ",
    delay: "0ms",
    desc: "Bảo trì định kỳ, đăng tải bài viết chuẩn SEO và bảo mật dữ liệu an toàn.",
    iconClass: "group-hover:rotate-90"
  },
  {
    title: "Quảng cáo Website",
    icon: "campaign",
    price: "1.500.000 vnđ",
    delay: "150ms",
    desc: "Tăng lưu lượng truy cập qua Google Ads, Facebook Ads tối ưu chuyển đổi.",
    iconClass: "group-hover:-rotate-12 group-hover:scale-110"
  },
  {
    title: "Gia hạn Website",
    icon: "update",
    price: "1.500.000 vnđ",
    delay: "300ms",
    desc: "Duy trì máy chủ tốc độ cao và giữ chỗ tên miền thương hiệu liên tục.",
    iconClass: "group-hover:rotate-180"
  },
  {
    title: "Nâng cấp Website",
    icon: "upgrade",
    price: "1.500.000 vnđ",
    delay: "450ms",
    desc: "Thiết kế lại chuẩn UI/UX hiện đại và tích hợp các tính năng công nghệ mới.",
    iconClass: "group-hover:-translate-y-1.5"
  }
];
---

<section
  id="services"
  class="py-20 md:py-32 px-6 sm:px-8 md:px-12 lg:px-16 bg-gradient-to-br from-base-100 to-base-200 relative overflow-hidden"
>
  <!-- Background Blobs -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-80 h-80 bg-primary/5 top-1/2 left-[80%]" style="animation-duration: 22s; animation-delay: -5s;"></div>
    <div class="floating-blob w-96 h-96 bg-info/5 bottom-[-50px] left-[-100px]" style="animation-duration: 18s;"></div>
  </div>

  <div class="max-w-[1280px] mx-auto relative z-10">
    <div
      class="text-center mb-20 space-y-4 scroll-animate fade-in-up"
    >
      <div class="inline-flex items-center gap-2 bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20">
        <p class="text-xs font-bold text-primary tracking-widest uppercase">
          Dịch Vụ Toàn Diện
        </p>
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-base-content">
        Các giải pháp dịch vụ phụ trợ
      </h2>
      <p
        class="text-base sm:text-lg text-base-content/70 max-w-2xl mx-auto leading-relaxed"
      >
        Hơn 10 năm hoạt động về dịch vụ Thiết kế Web Nha Trang, chúng tôi tự
        tin giúp quý khách sở hữu website chuyên nghiệp để quảng bá thương hiệu.
      </p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <div
          class="card rounded-3xl bg-base-100 shadow-xl border border-base-200/50 hover:shadow-2xl hover:border-primary/20 hover:-translate-y-2 transition-all duration-500 group scroll-animate fade-in-up cursor-pointer"
          style={`transition-delay: ${service.delay}`}
        >
          <div class="card-body p-6 sm:p-8 flex flex-col justify-between h-full">
            <div>
              <!-- Icon Container -->
              <div
                class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 border border-primary/10"
              >
                <span
                  class={`material-symbols-outlined text-primary text-3xl transition-all duration-500 ease-out ${service.iconClass}`}
                >
                  {service.icon}
                </span>
              </div>
              
              <h3 class="card-title text-lg font-bold text-base-content mb-3">
                {service.title}
              </h3>
              <p class="text-sm text-base-content/70 leading-relaxed font-medium mb-6">
                {service.desc}
              </p>
            </div>
            
            <div class="border-t border-base-200 pt-6">
              <p class="text-xs text-base-content/50 font-bold uppercase tracking-wider mb-1">
                Phí duy trì
              </p>
              <p class="text-lg font-black text-primary">{service.price}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
