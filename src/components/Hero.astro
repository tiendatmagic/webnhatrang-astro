---
---

<section
  class="relative pt-40 pb-20 md:pb-32 px-gutter overflow-hidden bg-gradient-to-br from-surface via-surface-container-low to-surface min-h-[95vh] flex items-center"
>
  <!-- Background Ambient Floating Blobs -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="floating-blob w-80 h-80 bg-primary-container/30 top-12 left-10" style="animation-duration: 16s;"></div>
    <div class="floating-blob w-[450px] h-[450px] bg-vibrant-blue/20 right-[-100px] top-[-50px]" style="animation-duration: 20s; animation-delay: -3s;"></div>
    <div class="floating-blob w-96 h-96 bg-secondary-container/20 bottom-10 left-[20%]" style="animation-duration: 18s; animation-delay: -7s;"></div>
  </div>

  <div class="absolute inset-0 hero-pattern z-0 opacity-40"></div>
  
  <div
    class="max-w-container-max mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center w-full"
  >
    <!-- Left Column Content -->
    <div class="space-y-6 scroll-animate fade-in-left is-visible">
      <div class="inline-flex items-center gap-2 bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10">
        <span class="w-2 h-2 rounded-full bg-primary animate-ping"></span>
        <p class="text-xs font-semibold text-primary tracking-widest uppercase">
          Chào mừng đến với Web Nha Trang
        </p>
      </div>
      <h1
        class="text-3xl sm:text-5xl lg:text-display-lg text-deep-navy leading-[1.15] font-extrabold tracking-tight"
      >
        Thiết kế website<br />
        <span class="text-gradient">Nha Trang</span><br />
        - Chuẩn SEO
      </h1>
      <p class="text-body-md md:text-body-lg text-on-surface-variant max-w-lg leading-relaxed">
        Hơn 10 năm hoạt động về dịch vụ Thiết kế Web Nha Trang, chúng tôi tự
        tin giúp quý khách sở hữu website chuyên nghiệp để quảng bá thương
        hiệu và tiếp cận khách hàng tiềm năng nhanh chóng nhất !
      </p>
      
      <div class="pt-4 flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a
          class="inline-flex items-center justify-center bg-gradient-primary text-on-primary px-8 py-4 rounded-full font-bold text-sm shadow-xl shadow-primary-container/25 hover:shadow-primary-container/40 hover:-translate-y-0.5 transition-all duration-300 relative overflow-hidden group shine-effect cursor-pointer w-full sm:w-auto text-center"
          href="https://zalo.me/0933663112"
        >
          <span class="relative">ĐĂNG KÝ WEB</span>
          <span
            class="material-symbols-outlined ml-2 relative text-lg group-hover:translate-x-1 transition-transform"
            data-icon="arrow_forward"
          >
            arrow_forward
          </span>
        </a>
        <a
          class="inline-flex items-center justify-center border border-primary/30 hover:border-primary text-primary px-8 py-4 rounded-full font-bold text-sm bg-white/40 hover:bg-primary/5 transition-all duration-300 backdrop-blur-md cursor-pointer w-full sm:w-auto text-center"
          href="#services"
        >
          <span>TÌM HIỂU THÊM</span>
        </a>
      </div>
    </div>
    
    <!-- Right Column Mockup Image -->
    <div class="relative scroll-animate fade-in-right is-visible mt-8 lg:mt-0">
      <!-- Ambient Glow Behind Image -->
      <div
        class="absolute -inset-4 bg-gradient-to-r from-primary-container to-vibrant-blue rounded-[2.5rem] blur-3xl opacity-25 animate-pulse"
        style="animation-duration: 5s;"
      ></div>
      
      <!-- Mockup Window -->
      <div
        class="glass-premium rounded-[2.5rem] p-4 relative overflow-hidden shadow-2xl shadow-deep-navy/5 transform hover:-translate-y-2.5 transition-all duration-500 hover:shadow-primary/10"
      >
        <div class="flex items-center gap-1.5 pb-3 px-2 border-b border-white/20 mb-3 opacity-60">
          <span class="w-3 h-3 rounded-full bg-red-400"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-400"></span>
        </div>
        <img
          alt="Tech office environment with modern setup"
          class="rounded-2xl w-full object-cover aspect-[4/3] shadow-inner"
          src="https://lh3.googleusercontent.com/aida/AP1WRLvTgJQBWzx0rRjh9xy63X5jf42It5sfp_mN1rYRpnddWjpXunof9BUMjLM9W1eeicDcJjw5ZYwmCVzbNiBSxIKgogX0LDwxWVNH8Wuvs3tOs7XRvate5XkyctgqIDQHGdK1LYxsEOlPe6glkphKtla88H2RPsuJlkExFaqnQmJJrdUne-TySkIZu2KsuvS1USiFY1KdoTHMmM8imeb2uu5K-R7R04YIpvr8pJVXLnpWvaZT-W919brjBhs"
        />
        
        <!-- Floating Interactive Badge -->
        <div
          class="absolute bottom-8 left-8 bg-white/90 backdrop-blur-md border border-white/60 rounded-2xl p-4 shadow-xl flex items-center gap-4 animate-float-slow z-20 hover:scale-105 transition-transform duration-300 select-none"
        >
          <div class="bg-primary/10 p-3 rounded-full relative">
            <div class="sonar-wave text-primary"></div>
            <span
              class="material-symbols-outlined text-primary text-2xl"
              data-icon="trending_up"
            >
              trending_up
            </span>
          </div>
          <div>
            <p class="font-bold text-sm text-deep-navy">Tăng trưởng SEO</p>
            <p class="text-xs font-semibold text-primary">+200% traffic</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
